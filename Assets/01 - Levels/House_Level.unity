--- !u!114 &138523322
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 138523321}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 01624bbce590d4fe08cf61c277479261, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DialogueDatabase
  onGameStart:
  - text: "\u2026 Quelle heure il est ?"
    displayDuration: 2
    delayBefore: 2
  - text: "Ugh.. J'ai d\xFB m'endormir devant la t\xE9l\xE9...."
    displayDuration: 2
    delayBefore: 2
  - text: Je devrais aller dormir...
    displayDuration: 5
    delayBefore: 2
  onFirstPickup:
  - text: "C'est pas grand-chose, mais \xE7a devrait faire l'affaire..."
    displayDuration: 2
    delayBefore: 1
  onTutorialStart:
  - text: "Zzz... J'ai d\xFB dormir deux heures... Peut-\xEAtre trois..."
    displayDuration: 3
    delayBefore: 2
  - text: Zzz... Au fond, je savais qu'il reviendrait...
    displayDuration: 3
    delayBefore: 2
  onFirstAttack:
  - text: "C'\xE9tait quoi ?!"
    displayDuration: 2
    delayBefore: 0
  - text: Non non non ! Il y'a quelqu'un dehors !
    displayDuration: 2
    delayBefore: 1
  - text: La porte ! Il faut bloquer la porte !
    displayDuration: 2
    delayBefore: 1
  onFirstBarricadeSuccess:
  - text: "Tiens bon\u2026 tiens bon\u2026"
    displayDuration: 3
    delayBefore: 1
  - text: "Ok... Ok \xE7a tient !"
    displayDuration: 3
    delayBefore: 1
  - text: Vite les autres portes !
    displayDuration: 3
    delayBefore: 1
  onBarricadeBreached: []
  onAccessBreached:
  - text: "Il est rentr\xE9 ?!"
    displayDuration: 2
    delayBefore: 1
  - text: Il est dans la maison !
    displayDuration: 2
    delayBefore: 1
  onLastMinute:
  - text: Encore un peu... Juste encore un peu...
    displayDuration: 2
    delayBefore: 1
  onAllBarricaded:
  - text: "Toutes les entr\xE9es sont barricad\xE9es !"
    displayDuration: 2
    delayBefore: 0
  - text: "C'est termin\xE9... !"
    displayDuration: 2
    delayBefore: 1
  onVictory:
  - text: C'est fini.
    displayDuration: 2
    delayBefore: 1
  - text: ...
    displayDuration: 2
    delayBefore: 1
  - text: C'est fini !
    displayDuration: 2
    delayBefore: 1
  - text: "Ti\xE9 le boss"
    displayDuration: 2
    delayBefore: 1
  onGameOver:
  - text: Matthieu..
    displayDuration: 2
    delayBefore: 1
  - text: "Ti\xE9 un tigre !"
    displayDuration: 2
    delayBefore: 1
